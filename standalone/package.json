{
  "name": "snow-desktop",
  "version": "1.0.0",
  "description": "满屏飘落 — 独立桌面版",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^31.0.0"
  },
  "build": {
    "appId": "com.snowman.snow",
    "productName": "满屏飘落",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "../dist/**/*",
      "../public/**/*"
    ],
    "win": {
      "target": "portable"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
